DATABASE_URL=sqlite:///./threatintel.db

# Free defaults (no paid AWS services required)
ENVIRONMENT=development
DISABLE_AUTH=false
LLM_PROVIDER=local
EMAIL_PROVIDER=log

# LLM_PROVIDER options: local | groq | bedrock
# EMAIL_PROVIDER options: log | ses

# AWS optional (required only when LLM_PROVIDER=bedrock and/or EMAIL_PROVIDER=ses)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-20250514-v1:0
SES_FROM_EMAIL=

# Groq optional (required only when LLM_PROVIDER=groq)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Auth
JWT_SECRET=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7

# Scheduler (UTC)
DAILY_PIPELINE_HOUR_UTC=6
DAILY_PIPELINE_MINUTE_UTC=0

# Public URL used in email unsubscribe links
APP_BASE_URL=http://localhost:3000

# Optional bootstrap admin user (created on first startup)
ADMIN_EMAIL=
ADMIN_PASSWORD=
